# Copy this file to .env for local development.
# Never commit .env, local databases, patient data, model weights, adapters,
# checkpoints, training outputs, wandb, mlruns, or cache directories.

# Local runtime
TCM_ENV=local
TCM_RUNTIME_MODE=local
TCM_RUNTIME_DIR=.runtime
TCM_ARTIFACTS_DIR=artifacts
TCM_TRACE_DIR=artifacts/traces
TCM_LOG_LEVEL=INFO
TCM_REDACT_LOGS=true
TCM_CONFIG_STRICT=false

# Storage
TCM_DB_BACKEND=sqlite
TCM_API_DB_PATH=.runtime/tcm_assistant.sqlite3
TCM_SQLITE_PATH=data/tcm_assistant.sqlite3
TCM_DB_URL=

# RAG fixtures
TCM_RAG_INDEX_PATH=knowledge/indexes/p6_bm25_index.json
TCM_CHUNKS_PATH=knowledge/processed/p6_chunks.jsonl

# LLM mode
# Keep fake for local gate validation. Use real_llm only after an explicit
# safety review and with keys supplied through a private .env or shell.
TCM_ALLOW_REAL_LLM=false
TCM_LLM_MODE=fake
OPENAI_API_KEY=
TCM_LLM_API_KEY=
TCM_LLM_BASE_URL=

# Device2 local vLLM / LoRA extractor smoke
# Use only after starting the isolated WSL vLLM service.
EXTRACTOR_BACKEND=local_lora
LOCAL_LLM_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_LLM_MODEL=tcm-extractor-lora
LOCAL_BASE_LLM_MODEL=/mnt/e/models/Qwen2.5-1.5B-Instruct
LOCAL_LORA_MODEL=tcm-extractor-lora
LOCAL_LLM_API_KEY=EMPTY
LOCAL_LLM_MAX_TOKENS=512
LOCAL_LLM_TEMPERATURE=0
LOCAL_LLM_RESPONSE_FORMAT=false
ALLOW_EXTRACTOR_FALLBACK=false
