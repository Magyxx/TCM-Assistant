# Copy this file to .env for local development.
# Never commit .env, local databases, patient data, model weights, adapters,
# checkpoints, training outputs, wandb, mlruns, or cache directories.

# Local runtime
# P1-F0 productization foundation defaults.
APP_ENV=local
APP_NAME=TCM-Assistant
ARTIFACTS_DIR=./artifacts
LOG_JSON=true
TCM_ENV=local
TCM_RUNTIME_MODE=local
TCM_RUNTIME_DIR=.runtime
TCM_ARTIFACTS_DIR=artifacts
TCM_TRACE_DIR=artifacts/traces
TCM_LOG_LEVEL=INFO
TCM_REDACT_LOGS=true
TCM_CONFIG_STRICT=false

# Storage
DATABASE_URL=sqlite:///./artifacts/local_demo.db
TCM_DB_BACKEND=sqlite
TCM_API_DB_PATH=.runtime/tcm_assistant.sqlite3
TCM_SQLITE_PATH=data/tcm_assistant.sqlite3
TCM_DB_URL=

# RAG fixtures
ENABLE_RAG=false
RAG_BACKEND=bm25_stub
TCM_RAG_INDEX_PATH=knowledge/indexes/p6_bm25_index.json
TCM_CHUNKS_PATH=knowledge/processed/p6_chunks.jsonl
RAG_MODE=hybrid
RAG_TOP_K=5
RAG_BM25_WEIGHT=0.55
RAG_DENSE_WEIGHT=0.45
RAG_ENABLE_DENSE_FALLBACK=true
RAG_INDEX_DIR=knowledge/indexes
RAG_CHUNKS_PATH=knowledge/processed/chunks.jsonl
RAG_CITATION_REQUIRED=true

# Extractor mode
# Keep fake for local gate validation. Supported contract modes:
# fake, fallback/rule_fallback, real_llm/openai_compatible/cloud_llm,
# local_lora, and reserved local_base. Use external backends only after an
# explicit safety review and with keys supplied through a private .env or shell.
TCM_ALLOW_REAL_LLM=false
TCM_LLM_MODE=fake
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
EXTRACTOR_BACKEND=fake
RAG_TOP_K=3
ENABLE_REAL_LLM=false
ENABLE_LOCAL_LORA=false
TCM_LLM_API_KEY=
TCM_LLM_BASE_URL=

# P10 FastAPI session service defaults
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
SESSION_STORE_BACKEND=sqlite
SESSION_SQLITE_PATH=artifacts/p10/p10_sessions.sqlite3
API_LOG_PATH=artifacts/p10/api_events.jsonl
ENABLE_API_EVAL_ENDPOINT=true
ENABLE_DEBUG_RAW_INPUT=false
P9M2_ALLOW_REAL_LLM_LIVE=false

# P10M2 local finalization
ENABLE_SAFETY_REDTEAM_ENDPOINT=true
ENABLE_FINAL_EVAL_ENDPOINT=true
REPORT_EXPORT_DIR=artifacts/p10m2/exports
DOCKER_APP_PORT=8000
DOCKER_SESSION_SQLITE_PATH=/app/artifacts/p10m2/p10m2_sessions.sqlite3

# P10M3/P10-M4A local LoRA extractor backend
# Device1 only calls an OpenAI-compatible local endpoint when explicitly selected.
# If the service is unavailable, validation records a skipped/fallback result.
# Optional. Only used when ENABLE_LOCAL_LORA=true and backend=local_lora.
LOCAL_LLM_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_LLM_MODEL=tcm-extractor-lora
LOCAL_LLM_TIMEOUT_SECONDS=10
LOCAL_LLM_API_KEY=
